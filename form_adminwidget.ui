  <property name="styleSheet">
   <string notr="true">
/* 全局字体设置 */
QWidget#DisplayWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;, sans-serif;
    background-color: #ecf0f1;
}

/* 顶部状态栏：深蓝色背景，白色字体 */
QFrame#headerFrame {
    background-color: #2980b9;
}
QLabel#lblTime, QLabel#lblWeather, QLabel#lblTips {
    color: #ffffff;
    font-size: 24px;
    font-weight: bold;
}

/* 新增的管理员登录按钮样式 */
QPushButton#btnAdminLogin {
    background-color: #34495e; /* 较深的颜色，显得低调 */
    color: #ffffff;
    border: 1px solid #bdc3c7;
    border-radius: 6px;
    padding: 8px 15px;
    font-size: 18px;
    font-weight: bold;
}
QPushButton#btnAdminLogin:hover {
    background-color: #2c3e50;
    border: 1px solid #ffffff;
}
QPushButton#btnAdminLogin:pressed {
    background-color: #1a252f;
}

/* 左侧视频播放区容器：纯黑背景 */
QWidget#videoContainer {
    background-color: #000000;
    border: 2px solid #bdc3c7;
    border-radius: 8px;
}
QLabel#lblVideoPlaceholder {
    color: #7f8c8d;
    font-size: 32px;
}

/* 右侧图片与图文展示区 */
QFrame#rightPanel {
    background-color: #ffffff;
    border: 2px solid #bdc3c7;
    border-radius: 8px;
}
QLabel#lblImage {
    background-color: #ebedef;
    border-radius: 6px;
}
QLabel#lblAnnouncement {
    color: #2c3e50;
    font-size: 20px;
    padding: 10px;
    background-color: #fdf2e9;
    border-radius: 6px;
    border-left: 5px solid #e67e22;
}

/* 底部紧急滚动字幕区：醒目的红底黄字 */
QFrame#footerFrame {
    background-color: #c0392b;
}
QLabel#lblScrollingText {
    color: #f1c40f;
    font-size: 36px;
    font-weight: bold;
    letter-spacing: 2px;
}
   </string>
