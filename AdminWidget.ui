  <property name="styleSheet">
   <string notr="true">
/* 全局样式 */
QWidget#AdminWidget {
    background-color: #f4f6f9;
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;, sans-serif;
}

/* 顶部标题栏 */
QFrame#headerFrame {
    background-color: #2c3e50;
}
QLabel#lblTitle {
    color: #ffffff;
    font-size: 28px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* 左侧导航菜单 */
QListWidget#listMenu {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 8px;
    font-size: 20px;
    outline: none;
}
QListWidget#listMenu::item {
    padding: 20px;
    border-bottom: 1px solid #f1f2f6;
    color: #2f3640;
}
QListWidget#listMenu::item:selected {
    background-color: #3498db;
    color: #ffffff;
    border-radius: 6px;
    font-weight: bold;
}

/* 右侧面板容器 */
QStackedWidget#stackedWidget {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 8px;
}

/* 组框样式 */
QGroupBox {
    font-size: 18px;
    font-weight: bold;
    color: #2980b9;
    border: 2px solid #ecf0f1;
    border-radius: 8px;
    margin-top: 25px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 10px;
    left: 15px;
}

/* 列表框与输入框 */
QListWidget, QLineEdit, QTextEdit {
    background-color: #f8f9fa;
    border: 1px solid #ced4da;
    border-radius: 6px;
    font-size: 18px;
    padding: 8px;
    color: #2c3e50;
}

/* 普通标签与复选框适配 */
QLabel#lblCity, QLabel#label_timer {
    font-size: 18px;
    font-weight: bold;
    color: #2c3e50;
}

QCheckBox#checkBox_timer {
    font-size: 18px;
    font-weight: bold;
    color: #2c3e50;
    spacing: 10px; 
}
QCheckBox::indicator {
    width: 24px;
    height: 24px;
}
QCheckBox::indicator:unchecked {
    background-color: #ffffff;
    border: 2px solid #bdc3c7;
    border-radius: 4px;
}
QCheckBox::indicator:checked {
    background-color: #3498db;
    border: 2px solid #3498db;
    border-radius: 4px;
}

/* 天气结果展示区背景 */
QWidget#weatherResultWidget {
    background-color: #ebf5fb;
    border-radius: 6px;
    border: 1px solid #d6eaf8;
}
QLabel#lblWeatherResult {
    color: #2980b9;
    font-size: 18px;
    line-height: 1.5; 
}

/* 按钮样式 */
QPushButton {
    background-color: #3498db;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 10px 15px;
    font-size: 18px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
    background-color: #1f618d;
}

/* 特殊控制按钮 */
QPushButton#btnVideoUp, QPushButton#btnVideoDown, QPushButton#btnImageUp, QPushButton#btnImageDown {
    background-color: #7f8c8d;
}
QPushButton#btnVideoDel, QPushButton#btnImageDel {
    background-color: #e74c3c;
}
QPushButton#btnVideoDel:hover, QPushButton#btnImageDel:hover {
    background-color: #c0392b;
}

/* 快捷输入按钮样式 (亮橙色) */
QPushButton#pushButton_quick {
    background-color: #e67e22;
    padding: 8px 12px;
}
QPushButton#pushButton_quick:hover {
    background-color: #d35400;
}

/* 底部全局应用按钮 */
QPushButton#btnApply {
    background-color: #27ae60;
    font-size: 22px;
    padding: 15px;
}
QPushButton#btnApply:hover {
    background-color: #2ecc71;
}
