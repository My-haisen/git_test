  <property name="styleSheet">
   <string notr="true">
/* 全局背景：采用深邃的蓝灰渐变，显得高端稳重 */
QWidget#LoginWidget {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #1a2a6c, stop:0.5 #b21f1f, stop:1 #fdbb2d); /* 若需纯色可改为 background-color: #2c3e50; */
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;, sans-serif;
}

/* 居中的登录卡片面板 */
QFrame#loginCard {
    background-color: rgba(255, 255, 255, 240); /* 半透明白色背景 */
    border-radius: 15px;
}

/* 系统标题 */
QLabel#lblSystemName {
    color: #2c3e50;
    font-size: 36px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* 副标题/提示语 */
QLabel#lblSubTitle {
    color: #7f8c8d;
    font-size: 18px;
}

/* 输入框通用样式 */
QLineEdit {
    background-color: #f8f9f9;
    border: 2px solid #bdc3c7;
    border-radius: 8px;
    padding: 12px 15px;
    font-size: 22px;
    color: #2c3e50;
}
QLineEdit:focus {
    border: 2px solid #3498db;
    background-color: #ffffff;
}

/* 登录按钮 */
QPushButton#btnLogin {
    background-color: #2980b9;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 24px;
    font-weight: bold;
    padding: 15px;
    margin-top: 10px;
}
QPushButton#btnLogin:hover {
    background-color: #3498db;
}
QPushButton#btnLogin:pressed {
    background-color: #1f618d;
}

/* 退出/关机按钮 */
QPushButton#btnExit {
    background-color: transparent;
    color: #95a5a6;
    border: none;
    font-size: 18px;
    text-decoration: underline;
}
QPushButton#btnExit:hover {
    color: #e74c3c;
}
   </string>
