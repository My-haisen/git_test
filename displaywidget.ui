  <property name="styleSheet">
   <string notr="true">
/* ================= 全局背景 ================= */
QWidget#DisplayWidget {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #0f2027, stop:0.5 #203a43, stop:1 #2c5364);
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;, sans-serif;
}

/* ================= 视频播放区 (锁定左上角0,0) ================= */
QWidget#videoContainer {
    background-color: #050505;
    /* 去除左上角圆角，贴合物理屏幕 */
    border-bottom-right-radius: 8px;
    border-right: 2px solid rgba(255,255,255,20);
    border-bottom: 2px solid rgba(255,255,255,20);
}
QLabel#lblVideoPlaceholder {
    color: #7f8c8d;
    font-size: 18px;
    letter-spacing: 1px;
}

/* ================= 右侧图文展示区 ================= */
QFrame#rightPanel {
    background-color: transparent;
    margin-top: 10px; /* 防止贴住屏幕顶边 */
}

QLabel#lblImage {
    background-color: rgba(0, 0, 0, 80);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,20);
    color: #bdc3c7;
    font-size: 16px;
}

QLabel#lblAnnouncement {
    background-color: rgba(255, 255, 255, 245);
    color: #2c3e50;
    font-size: 15px;
    line-height: 1.5;
    padding: 12px;
    border-radius: 8px;
    border-left: 5px solid #3498db; 
}

/* ================= 中间控制栏 (原Header) ================= */
QFrame#headerFrame {
    background-color: rgba(255, 255, 255, 20); 
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 30);
    margin-left: 10px; /* 防止贴住屏幕左边 */
}

QLabel#lblTime {
    color: #ffffff; 
    font-size: 18px;
    font-weight: bold;
    font-family: &quot;Arial&quot;;
    background-color: rgba(0, 0, 0, 60);
    padding: 2px 10px;
    border-radius: 6px;
}

QLabel#lblWeather {
    font-size: 16px;
    font-weight: bold;
}

QLabel#lblTips {
    color: #ecf0f1;
    font-size: 14px;
}

QLabel#client_label {
    color: #e74c3c; 
    font-size: 14px;
    font-weight: bold;
    padding: 0 5px;
}

QPushButton#btnAdminLogin {
    background-color: rgba(52, 152, 219, 180);
    color: #ffffff;
    border: 1px solid #3498db;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 14px;
    font-weight: bold;
}
QPushButton#btnAdminLogin:hover {
    background-color: #2980b9;
}
QPushButton#btnAdminLogin:pressed {
    background-color: #1c2833;
}

QPushButton#pushButton_videomute {
    background-color: rgba(46, 204, 113, 180);
    color: #ffffff;
    border: 1px solid #2ecc71;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 14px;
    font-weight: bold;
}
QPushButton#pushButton_videomute:hover {
    background-color: #27ae60;
}

/* ================= 底部跑马灯 ================= */
QFrame#footerFrame {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #cb2d3e, stop:1 #ef473a);
    border-radius: 8px;
    border: 1px solid #e74c3c;
    margin-left: 10px; /* 防止贴住屏幕左边 */
}
QLabel#lblScrollingText {
    color: #ffffff;
    font-size: 24px;
    font-weight: bold;
    letter-spacing: 2px;
}
   </string>
